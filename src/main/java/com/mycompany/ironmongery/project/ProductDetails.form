                    <Component class="javax.swing.JTextArea" name="txtDescripcion">
                      <Properties>
                        <Property name="columns" type="int" value="20"/>
                        <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                          <Font name="Segoe UI" size="14" style="0"/>
                        </Property>
                        <Property name="rows" type="int" value="5"/>
                        <Property name="text" type="java.lang.String" value="Martillo de acero forjado dise&#xf1;ado para trabajos de carpinter&#xed;a &#xa;y construcci&#xf3;n ligera. Cuenta con una cabeza resistente que proporciona &#xa;golpes precisos y eficientes al clavar o extraer clavos. Su mango&#xa; ergon&#xf3;mico ofrece un agarre c&#xf3;modo y seguro, reduciendo la fatiga &#xa;durante el uso prolongado. Ideal para profesionales y aficionados que &#xa;buscan una herramienta duradera y de alto rendimiento."/>
                      </Properties>
                    </Component>
                  </SubComponents>
                </Container>
